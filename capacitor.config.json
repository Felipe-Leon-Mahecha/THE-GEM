{
  "appId": "com.felixcompany.thegem",
  "appName": "THE GEM",
  "webDir": "dist",
  "android": {
    "backgroundColor": "#050505",
    "allowMixedContent": true,
    "initialFocus": true
  },
  "plugins": {
    "StatusBar": {
      "overlaysWebView": false,
      "style": "DARK",
      "backgroundColor": "#00000000"
    },
    "FirebaseAuthentication": {
      "skipNativeAuth": false,
      "providers": [
        "google.com"
      ],
      "googleSignInMode": "legacy"
    }
  }
}